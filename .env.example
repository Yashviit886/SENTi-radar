# ─── Scrape.do (web scraping proxy — X, Reddit, news) ───────────────────────
# Get your token at https://scrape.do/dashboard
# IMPORTANT: Any VITE_ prefixed variable is embedded in the client bundle and
# visible to end-users who inspect the JavaScript.  For a production deployment,
# move X / Reddit fetching to Supabase Edge Functions and store the token there
# as a Supabase Secret (see README for details).
VITE_SCRAPE_TOKEN=your_scrape_do_token_here

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# Required for YouTube comment fetching (server-side edge function only)
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── AI / LLM keys (optional — app degrades gracefully without them) ─────────
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here

# ─── Supabase (required) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
